2.Second Largest


class Solution {
    public int getSecondLargest(int[] arr) {
        
        int largest = -1;
        int secondLargest = -1;
        
        for(int i = 0; i < arr.length; i++){
            
            if(arr[i] > largest){
                secondLargest = largest;
                largest = arr[i];
            }
            else if(arr[i] > secondLargest && arr[i] != largest){
                secondLargest = arr[i];
            }
        }
        
        return secondLargest;
    }
}

Input: arr[] = [12, 35, 1, 10, 34, 1]
Output: 34
