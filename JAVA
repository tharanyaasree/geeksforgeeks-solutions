Missing in Array

class Solution {
    int missingNum(int arr[]) {
        
        long n = arr.length + 1;
        long total = n * (n + 1) / 2;
        long sum = 0;
        
        for(int i = 0; i < arr.length; i++){
            sum += arr[i];
        }
        
        return (int)(total - sum);
    }
}
input: 1 2 3 5
output: 4

